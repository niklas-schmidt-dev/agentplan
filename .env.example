# --- Database (PlanetScale Postgres) ---
# Runtime connection through PgBouncer, port 6432. Used by the application.
DATABASE_URL=
# Migration/DDL connection, port 5432. Used only by Drizzle Kit.
DATABASE_URL_DIRECT=

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- GitHub OAuth app ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cloudflare R2 (private bucket, S3-compatible API) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=agentplan
