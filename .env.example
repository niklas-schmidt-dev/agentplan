# --- Database (PlanetScale Postgres) ---
# Runtime connection through PgBouncer, port 6432. Used by the application.
DATABASE_URL=
# Migration/DDL connection, port 5432. Used only by Drizzle Kit.
DATABASE_URL_DIRECT=

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# On an empty database, this exact normalized address is the only identity
# allowed to create the first account. That account is atomically made admin.
ADMIN_BOOTSTRAP_EMAIL=

# Email/password accounts must verify their mailbox. The webhook receives
# POST JSON { kind, to, name, url, from } and must return 2xx.
AUTH_EMAIL_WEBHOOK_URL=
AUTH_EMAIL_WEBHOOK_SECRET=
AUTH_EMAIL_FROM=AgentPlan

# --- GitHub OAuth app (optional) ---
# When unset, the login page offers email/password only.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cloudflare R2 (private bucket, S3-compatible API) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=agentplan

# --- Abuse protection ---
# Authorizes the daily purge cron (/api/cron/purge). Vercel sends it
# automatically when the env var is set. Generate with: openssl rand -hex 32
CRON_SECRET=
# Free-plan limits are tunable without a deploy (defaults in lib/limits/plans.ts):
# AP_MAX_DRAFTS_PER_USER, AP_MAX_VERSIONS_PER_DRAFT, AP_MAX_STORAGE_BYTES_PER_USER,
# AP_MAX_ACTIVE_TOKENS_PER_USER, AP_UPLOADS_PER_10MIN, AP_UPLOADS_PER_DAY,
# AP_PASSWORD_ATTEMPTS_PER_15MIN, AP_DELETED_RETENTION_DAYS,
# AP_TOKEN_MUTATIONS_PER_HOUR, AP_TOKEN_MUTATIONS_PER_DAY,
# AP_RETIRED_TOKEN_RETENTION_DAYS, AP_AUDIT_RETENTION_DAYS
